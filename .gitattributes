# Default: auto-detect line endings
* text=auto

# Force LF for shell scripts and server-side files
*.sh         text eol=lf
*.bash       text eol=lf

# Force LF for source files (consistent across platforms)
*.astro      text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.json       text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
.nvmrc       text eol=lf
.gitignore   text eol=lf

# Binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.svg        text eol=lf
*.woff       binary
*.woff2      binary
