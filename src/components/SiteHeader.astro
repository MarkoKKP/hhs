---
import { useTranslations, languages, type Lang } from '../i18n/ui';
import { bookingUrl } from '../i18n/ui';

interface Props {
  lang?: Lang;
  variant?: 'dark' | 'light';
}

const { lang = 'sr', variant = 'dark' } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { key: 'nav.home', href: lang === 'sr' ? '/' : `/${lang}/` },
  { key: 'nav.gallery', href: lang === 'sr' ? '/galerija/' : `/${lang}/gallery/` },
  { key: 'nav.location', href: lang === 'sr' ? '/kumbor/' : `/${lang}/kumbor/` },
  { key: 'nav.about', href: lang === 'sr' ? '/o-nama/' : `/${lang}/about/` }
] as const;
---
<header class={`site-header site-header--${variant}`}>
  <div class="container site-header__inner">
    <a href={lang === 'sr' ? '/' : `/${lang}/`} class="site-header__logo" aria-label="House Hill Star — Početna">
      <span>HOUSE</span>
      <svg class="star" viewBox="0 0 24 24" aria-hidden="true">
        <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" />
      </svg>
      <span>HILL</span>
      <svg class="star" viewBox="0 0 24 24" aria-hidden="true">
        <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" />
      </svg>
      <span>STAR</span>
    </a>

    <nav class="site-header__nav" aria-label="Glavna navigacija">
      {navItems.map(item => (
        <a href={item.href}>{t(item.key as any)}</a>
      ))}
    </nav>

    <div class="site-header__meta">
      <div class="lang-switch">
        {Object.keys(languages).map(code => (
          <a
            href={code === 'sr' ? '/' : `/${code}/`}
            class={code === lang ? 'is-active' : ''}
            aria-current={code === lang ? 'page' : undefined}
          >
            {languages[code as Lang].label}
          </a>
        ))}
      </div>
      <a href={bookingUrl[lang]} target="_blank" rel="noopener" class="book-btn">
        {t('nav.book')}
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding-block: 28px;
  }

  .site-header--dark { color: var(--color-text-on-dark); }
  .site-header--light { color: var(--color-text); }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .site-header__logo {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .site-header__logo .star {
    width: 12px;
    height: 12px;
    fill: var(--color-accent);
    flex: 0 0 12px;
  }

  .site-header__nav {
    display: flex;
    gap: 32px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .site-header__nav a {
    position: relative;
    padding-block: 4px;
  }

  .site-header__nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width var(--duration-base) var(--ease);
  }

  .site-header__nav a:hover::after { width: 100%; }

  .site-header__meta {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .lang-switch {
    display: flex;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
  }

  .lang-switch a {
    opacity: 0.5;
    transition: opacity var(--duration-base) var(--ease);
  }

  .lang-switch a.is-active,
  .lang-switch a:hover { opacity: 1; color: var(--color-accent); }

  .book-btn {
    padding: 10px 22px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: background var(--duration-base) var(--ease), color var(--duration-base) var(--ease);
  }

  .book-btn:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .site-header__nav { display: none; }
    .site-header__meta .lang-switch { display: none; }
  }
</style>
