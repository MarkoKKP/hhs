---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { useTranslations, bookingUrl } from '../i18n/ui';

const lang = 'sr' as const;
const t = useTranslations(lang);

const pageTitle = 'House Hill Star — Privatna vila iznad Bokokotorskog zaliva';
const pageDesc = 'Privatna vila u Kumboru, iznad Portonovog. Jedna kuća, jedan par, jedan pogled na Bokokotorski zaliv. Rezervacije preko Booking.com.';
---
<BaseLayout lang={lang} title={pageTitle} description={pageDesc}>
  <SiteHeader slot="header" lang={lang} variant="dark" />

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="eyebrow">{t('hero.eyebrow')}</div>
      <h1 class="display hero__title">
        {t('hero.title.line1')} <em>{t('hero.title.line1.accent')}</em><br />
        {t('hero.title.line2')} <em>{t('hero.title.line2.accent')}</em>
      </h1>
      <p class="lede hero__lede">{t('hero.lede')}</p>
      <div class="hero__cta">
        <a class="btn-primary" href={bookingUrl[lang]} target="_blank" rel="noopener">
          {t('hero.cta.primary')}
        </a>
        <a class="btn-ghost" href="#about">
          {t('hero.cta.secondary')}
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1" fill="none"/>
          </svg>
        </a>
      </div>

      <div class="hero__meta">
        <div class="meta-item">
          <div class="meta-item__num">{t('meta.private.value')}</div>
          <div class="meta-item__label">{t('meta.private')}</div>
        </div>
        <div class="meta-item">
          <div class="meta-item__num">{t('meta.beach.value')}</div>
          <div class="meta-item__label">{t('meta.beach')}</div>
        </div>
        <div class="meta-item">
          <div class="meta-item__num">∞</div>
          <div class="meta-item__label">{t('meta.view')}</div>
        </div>
        <div class="meta-item">
          <div class="meta-item__num">2</div>
          <div class="meta-item__label">{t('meta.guests')}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INTRO (editorial 2-col) ============ -->
  <section class="intro section dark-surface" id="about">
    <div class="container intro__grid">
      <div class="intro__copy">
        <div class="eyebrow">{t('intro.eyebrow')}</div>
        <h2 class="h2 intro__title">
          {t('intro.title.line1')}<br />
          <em class="gold">{t('intro.title.line2.accent')}</em>
        </h2>
      </div>
      <p class="lede intro__body">{t('intro.body')}</p>
    </div>
  </section>

  <!-- ============ SIGNATURE (light, 2-col with card) ============ -->
  <section class="signature section">
    <div class="container signature__grid">
      <div>
        <div class="eyebrow eyebrow--dark">{t('signature.label')}</div>
        <h2 class="h2 signature__title">{t('signature.title')}</h2>
        <p class="signature__body">{t('signature.body')}</p>
      </div>
      <figure class="signature__media">
        <div class="signature__media-frame">
          <span class="signature__media-placeholder">terrace-sunset-01.jpg</span>
        </div>
        <figcaption>Zapadna terasa pri zalasku. Pogled na Portonovi.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ LOCATION (full-bleed quote / map teaser) ============ -->
  <section class="location section dark-surface">
    <div class="container">
      <div class="location__head">
        <div class="eyebrow">{t('location.eyebrow')}</div>
        <h2 class="display location__title">
          {t('location.title')} <em>{t('location.title.accent')}</em>
        </h2>
      </div>
      <p class="lede location__body">{t('location.body')}</p>
      <a class="btn-ghost" href="/kumbor/">
        {t('location.cta')}
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1" fill="none"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ============ GALLERY TEASER ============ -->
  <section class="gallery section">
    <div class="container">
      <div class="gallery__head">
        <div class="eyebrow eyebrow--dark">{t('gallery.eyebrow')}</div>
        <h2 class="h2 gallery__title">
          {t('gallery.title')} <em class="gold">{t('gallery.title.accent')}</em>
        </h2>
        <p class="gallery__body">{t('gallery.body')}</p>
      </div>
      <div class="gallery__grid">
        <figure class="gallery__item gallery__item--tall">
          <div class="gallery__frame">
            <span class="gallery__placeholder">terrace-sunset-01.jpg</span>
          </div>
          <figcaption>{t('gallery.1.caption')}</figcaption>
        </figure>
        <figure class="gallery__item">
          <div class="gallery__frame">
            <span class="gallery__placeholder">interior-living-01.jpg</span>
          </div>
          <figcaption>{t('gallery.2.caption')}</figcaption>
        </figure>
        <figure class="gallery__item">
          <div class="gallery__frame">
            <span class="gallery__placeholder">garden-day-01.jpg</span>
          </div>
          <figcaption>{t('gallery.3.caption')}</figcaption>
        </figure>
        <figure class="gallery__item gallery__item--wide">
          <div class="gallery__frame">
            <span class="gallery__placeholder">views-bay-twilight-01.jpg</span>
          </div>
          <figcaption>{t('gallery.4.caption')}</figcaption>
        </figure>
      </div>
      <a class="btn-ghost gallery__cta" href="/galerija/">
        {t('gallery.cta')}
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1" fill="none"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ============ REVIEWS (curated static cards) ============ -->
  <section class="reviews section dark-surface">
    <div class="container">
      <div class="reviews__head">
        <div class="eyebrow">{t('reviews.eyebrow')}</div>
        <h2 class="h2 reviews__title">
          {t('reviews.title')} <em class="gold">{t('reviews.title.accent')}</em>
        </h2>
        <p class="reviews__body">{t('reviews.body')}</p>
      </div>
      <div class="reviews__grid">
        <blockquote class="review-card">
          <svg class="review-card__mark" viewBox="0 0 24 24" aria-hidden="true">
            <polygon points="12,2 14,10 22,12 14,14 12,22 10,14 2,12 10,10" fill="currentColor"/>
          </svg>
          <p class="review-card__quote">{t('review.1.quote')}</p>
          <footer class="review-card__author">
            <span class="review-card__name">{t('review.1.author')}</span>
            <span class="review-card__origin">{t('review.1.origin')}</span>
          </footer>
        </blockquote>
        <blockquote class="review-card">
          <svg class="review-card__mark" viewBox="0 0 24 24" aria-hidden="true">
            <polygon points="12,2 14,10 22,12 14,14 12,22 10,14 2,12 10,10" fill="currentColor"/>
          </svg>
          <p class="review-card__quote">{t('review.2.quote')}</p>
          <footer class="review-card__author">
            <span class="review-card__name">{t('review.2.author')}</span>
            <span class="review-card__origin">{t('review.2.origin')}</span>
          </footer>
        </blockquote>
        <blockquote class="review-card">
          <svg class="review-card__mark" viewBox="0 0 24 24" aria-hidden="true">
            <polygon points="12,2 14,10 22,12 14,14 12,22 10,14 2,12 10,10" fill="currentColor"/>
          </svg>
          <p class="review-card__quote">{t('review.3.quote')}</p>
          <footer class="review-card__author">
            <span class="review-card__name">{t('review.3.author')}</span>
            <span class="review-card__origin">{t('review.3.origin')}</span>
          </footer>
        </blockquote>
      </div>
      <a class="btn-ghost reviews__cta" href={bookingUrl[lang]} target="_blank" rel="noopener">
        {t('reviews.cta')}
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1" fill="none"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ============ CLOSING CTA ============ -->
  <section class="closing-cta section dark-surface">
    <div class="container closing-cta__inner">
      <h2 class="display closing-cta__title">
        {t('cta.title.line1')}<br />
        <em>{t('cta.title.line2.accent')}</em>
      </h2>
      <p class="lede closing-cta__body">{t('cta.body')}</p>
      <a class="btn-primary" href={bookingUrl[lang]} target="_blank" rel="noopener">
        {t('cta.primary')}
      </a>
    </div>
  </section>

  <SiteFooter slot="footer" lang={lang} />
</BaseLayout>

<style>
  /* ============ HERO ============ */
  .hero {
    background: var(--gradient-hero);
    color: var(--color-text-on-dark);
    min-height: 100vh;
    padding-top: 120px;
    padding-bottom: var(--space-7);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 700px;
    height: 700px;
    background: var(--gradient-gold-glow);
    pointer-events: none;
  }

  .hero__inner { position: relative; z-index: 2; width: 100%; }

  .hero__title {
    margin: var(--space-4) 0 var(--space-4);
    max-width: 920px;
  }

  .hero__lede {
    max-width: 560px;
    margin: 0 0 var(--space-5);
    color: #C8C4D4;
  }

  .hero__cta {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-dark);
  }

  .meta-item__num {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    color: var(--color-accent);
    font-weight: 400;
    line-height: 1;
  }

  .meta-item__label {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted-dark);
    margin-top: var(--space-1);
  }

  /* ============ INTRO ============ */
  .intro__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-7);
    align-items: start;
  }

  .intro__title { margin: var(--space-3) 0 0; }
  .intro__body { margin: 0; max-width: 560px; }

  /* ============ SIGNATURE ============ */
  .signature__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .eyebrow--dark { color: var(--color-accent-deep); }
  .eyebrow--dark::before,
  .eyebrow--dark::after { background: var(--color-accent-deep); }

  .signature__title { margin: var(--space-3) 0 var(--space-3); }
  .signature__body {
    font-size: var(--text-lede);
    line-height: 1.7;
    color: var(--color-text);
    max-width: 480px;
    margin: 0;
  }

  .signature__media-frame {
    aspect-ratio: 4/5;
    background:
      linear-gradient(180deg, #2D3458 0%, #0F1226 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .signature__media-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 30%, rgba(200,169,107,0.25), transparent 60%);
  }

  .signature__media-placeholder {
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--text-small);
    letter-spacing: 0.1em;
    font-style: italic;
    opacity: 0.6;
    z-index: 2;
  }

  .signature__media figcaption {
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-text-muted);
  }

  /* ============ LOCATION ============ */
  .location__head { margin-bottom: var(--space-5); }
  .location__title {
    margin: var(--space-3) 0 0;
    max-width: 800px;
  }
  .location__body {
    max-width: 640px;
    margin: 0 0 var(--space-4);
  }

  /* ============ GALLERY ============ */
  .gallery__head {
    max-width: 640px;
    margin-bottom: var(--space-6);
  }
  .gallery__title { margin: var(--space-3) 0 var(--space-3); }
  .gallery__body {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 480px;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .gallery__item { margin: 0; }

  .gallery__item--tall { grid-row: span 2; }
  .gallery__item--wide { grid-column: span 2; }

  .gallery__frame {
    aspect-ratio: 4/5;
    background: linear-gradient(180deg, #2D3458 0%, #0F1226 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 30%, rgba(200,169,107,0.18), transparent 60%);
  }

  .gallery__item--tall .gallery__frame { aspect-ratio: 4/9; }
  .gallery__item--wide .gallery__frame { aspect-ratio: 8/5; }

  .gallery__placeholder {
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--text-small);
    letter-spacing: 0.1em;
    font-style: italic;
    opacity: 0.55;
    z-index: 2;
  }

  .gallery__item figcaption {
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-text-muted);
  }

  /* ============ REVIEWS (dark, 3-card editorial) ============ */
  .reviews__head {
    max-width: 720px;
    margin-bottom: var(--space-6);
  }
  .reviews__title { margin: var(--space-3) 0 var(--space-3); }
  .reviews__body {
    color: var(--color-text-muted-dark);
    margin: 0;
    max-width: 520px;
    line-height: 1.7;
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .review-card {
    margin: 0;
    padding: var(--space-5) var(--space-4);
    background: linear-gradient(180deg, #1A1F3A 0%, #2D3458 100%);
    border: 1px solid var(--color-border-dark);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .review-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 60px;
    height: 1px;
    background: var(--color-accent);
  }

  .review-card__mark {
    width: 22px;
    height: 22px;
    color: var(--color-accent);
    flex: 0 0 22px;
  }

  .review-card__quote {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.5;
    color: var(--color-text-on-dark);
    margin: 0;
    flex: 1;
  }

  .review-card__author {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-dark);
  }

  .review-card__name {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .review-card__origin {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    color: var(--color-text-muted-dark);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .gallery__cta,
  .reviews__cta { display: inline-flex; }

  /* ============ CLOSING CTA ============ */
  .closing-cta__inner {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .closing-cta__title { margin: 0 0 var(--space-3); }
  .closing-cta__body {
    margin: 0 auto var(--space-5);
    max-width: 480px;
    color: var(--color-text-muted-dark);
  }

  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .hero { padding-top: 100px; min-height: auto; }
    .hero__meta {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
    .intro__grid,
    .signature__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .gallery__grid,
    .reviews__grid {
      grid-template-columns: 1fr;
    }
    .gallery__item--tall,
    .gallery__item--wide {
      grid-row: auto;
      grid-column: auto;
    }
    .gallery__item--tall .gallery__frame {
      aspect-ratio: 4/5;
    }
    .gallery__item--wide .gallery__frame {
      aspect-ratio: 4/5;
    }
  }
</style>
